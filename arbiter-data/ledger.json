{
  "version": 0,
  "wards": [
    {
      "id": "downloads-folder",
      "path": "C:\\Users\\user\\Downloads",
      "pattern": "*",
      "layer": "Surface"
    }
  ],
  "ordinances": [
    {
      "id": "pdf-organizer",
      "label": "Auto-Archive PDFs",
      "summons": {
        "type": "FileCreated",
        "data": {
          "ward_id": "C:\\Users\\user\\Downloads",
          "pattern": "*.pdf"
        }
      },
      "nodes": [
        {
          "id": "entry",
          "label": "Start",
          "internal_state": "",
          "kind": "Entry",
          "next_nodes": {
            "Next": "move-pdf"
          }
        },
        {
          "id": "move-pdf",
          "label": "Move to PDFs",
          "internal_state": "{\"action_type\":{\"InscribeMove\":{\"source\":\"${env.file_path}\",\"destination\":\"C:\\\\Users\\\\user\\\\Documents\\\\PDFs\\\\\"}},\"point\":null,\"delay_ms\":500}",
          "kind": "Action",
          "next_nodes": {}
        }
      ],
      "presence_config": {
        "ignore_mouse": true,
        "ignore_keyboard": true
      }
    },
    {
      "id": "report-sorter",
      "label": "Sort Business Reports",
      "summons": {
        "type": "FileCreated",
        "data": {
          "ward_id": "C:\\Users\\user\\Downloads",
          "pattern": "{report,data}_*.{csv,xlsx}"
        }
      },
      "nodes": [
        {
          "id": "entry",
          "label": "Start",
          "internal_state": "",
          "kind": "Entry",
          "next_nodes": {
            "Next": "move-report"
          }
        },
        {
          "id": "move-report",
          "label": "Archive Report",
          "internal_state": "{\"action_type\":{\"InscribeMove\":{\"source\":\"${env.file_path}\",\"destination\":\"C:\\\\Users\\\\user\\\\Documents\\\\Reports\\\\Archive\\\\\"}},\"point\":null,\"delay_ms\":200}",
          "kind": "Action",
          "next_nodes": {}
        }
      ],
      "presence_config": {
        "ignore_mouse": true,
        "ignore_keyboard": true
      }
    },
    {
      "id": "notepad-header",
      "label": "Notepad Auto-Header",
      "summons": {
        "type": "ProcessAppeared",
        "data": {
          "name": "notepad.exe"
        }
      },
      "nodes": [
        {
          "id": "entry",
          "label": "Start",
          "internal_state": "",
          "kind": "Entry",
          "next_nodes": {
            "Next": "type-header"
          }
        },
        {
          "id": "type-header",
          "label": "Type Log Header",
          "internal_state": "{\"action_type\":{\"Type\":\"--- ARBITER SESSION START ---\\nDate: ${env.timestamp}\\nSource: ${env.process_name}\\n----------------------------\\n\"},\"point\":null,\"delay_ms\":0}",
          "kind": "Action",
          "next_nodes": {}
        }
      ],
      "presence_config": {
        "ignore_mouse": false,
        "ignore_keyboard": false
      }
    },
    {
      "id": "edge-shortcut",
      "label": "Open Edge",
      "summons": {
        "type": "Hotkey",
        "data": {
          "combo": "Ctrl+Alt+U"
        }
      },
      "nodes": [
        {
          "id": "entry",
          "label": "Start",
          "internal_state": "",
          "kind": "Entry",
          "next_nodes": {
            "Next": "step-1"
          }
        },
        {
          "id": "step-1",
          "label": "Launch Edge",
          "internal_state": "{\"action_type\":{\"Shell\":{\"command\":\"C:\\\\Program Files (x86)\\\\Microsoft\\\\Edge\\\\Application\\\\msedge.exe\",\"args\":[],\"detached\":true}},\"point\":null,\"delay_ms\":0}",
          "kind": "Action",
          "next_nodes": {}
        }
      ],
      "presence_config": {
        "ignore_mouse": true,
        "ignore_keyboard": true
      }
    }
  ]
}
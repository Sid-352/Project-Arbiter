  "decrees": [
    {
      "id": "decree-notepad-header",
      "label": "Notepad: Auto-Header",
      "summons": {
        "type": "ProcessAppeared",
        "data": {
          "name": "notepad.exe"
        }
      },
      "nodes": [
        {
          "id": "entry",
          "label": "Start",
          "internal_state": "",
          "kind": "Entry",
          "next_nodes": {
            "Next": "wait-notepad"
          }
        },
        {
          "id": "wait-notepad",
          "label": "Steady Wait",
          "internal_state": "{\"action_type\":{\"Wait\":600},\"point\":null,\"delay_ms\":0}",
          "kind": "Action",
          "next_nodes": {
            "Next": "type-header"
          }
        },
        {
          "id": "type-header",
          "label": "Type Session Header",
          "internal_state": "{\"action_type\":{\"Type\":\"--- SESSION START ---\\nTime: ${env.timestamp_local}\\n---------------------\"},\"point\":null,\"delay_ms\":0}",
          "kind": "Action",
          "next_nodes": {}
        }
      ],
      "presence_config": {
        "ignore_mouse": false,
        "ignore_keyboard": false
      }
    },
    {
      "id": "decree-hotkey-lock",
      "label": "Hotkey: Lock Workstation",
      "summons": {
        "type": "Hotkey",
        "data": {
          "combo": "ctrl+alt+l"
        }

{
  "version": 1,
  "wards": [
    {
      "id": "downloads-ward",
      "path": "C:\\Users\\user\\Downloads",
      "pattern": "*",
      "layer": "Surface",
      "recursive": true
    },
    {
      "id": "arbtest-ward",
      "path": "N:\\Temp\\arbtest",
      "pattern": "*",
      "layer": "Surface",
      "recursive": true

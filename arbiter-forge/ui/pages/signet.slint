import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ActionButton, InputPill } from "../widgets.slint";

export component SignetPage inherits Rectangle {
    in-out property <[string]> trusted-paths: [];
    in-out property <[string]> baton-allowed: [];
    callback add-trusted-path;
    callback remove-trusted-path(int);
    callback update-trusted-path(int, string);
    callback add-baton;
    callback update-baton(int, string);
    callback remove-baton(int);
    callback pick-folder() -> string;
    callback save;

    ScrollView {
        VerticalLayout {
            padding: Theme.space-xxxl;
            spacing: Theme.space-xxl;
            alignment: start;

            HorizontalLayout {
                Text { text: "THE SIGNET (AUTHORITY)"; color: Theme.accent; font-weight: 800; font-size: Theme.font-small; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                ActionButton { label: "COMMIT CHANGES"; primary: true; clicked => { root.save(); } }
            }

            Text { 
                text: "The Signet establishes hard boundaries for the engine's operational capabilities. Actions mapped within decrees will instantly fail if they contravene these security parameters.";
                color: Theme.text-secondary; font-size: Theme.font-norm; wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: Theme.space-xxl;
                
                // Left Column: Trusted Paths
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: Theme.space-lg;
                    
                    Text { text: "TRUSTED ROOTS (READ/WRITE)"; color: Theme.text-main; font-weight: 700; font-size: Theme.font-small; }
                    Text { text: "Directories Arbiter is permitted to perform Inscribe Move/Copy actions to or from."; color: Theme.text-muted; font-size: Theme.font-tiny+1px; wrap: word-wrap; }
                    
                    for p[idx] in root.trusted-paths: HorizontalLayout {
                        spacing: Theme.space-md;
                        InputPill { 
                            value: p; 
                            placeholder: "Directory Path..."; 
                            monospaced: true; 
                            horizontal-stretch: 1; 
                            committed(v) => { root.update-trusted-path(idx, v); } 
                        }
                        ActionButton { 
                            label: "BROWSE"; 
                            clicked => { 
                                let picked = root.pick-folder();
                                if (picked != "") {
                                    root.update-trusted-path(idx, picked);
                                }
                            } 
                        }
                        ta-remove-tp := TouchArea {
                            width: Theme.btn-height; height: Theme.btn-height;
                            clicked => { root.remove-trusted-path(idx); }
                            Rectangle {
                                border-radius: Theme.radius/2; background: ta-remove-tp.has-hover ? #ef444420 : transparent;
                                Path { width: 12px; height: 12px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; stroke: ta-remove-tp.has-hover ? Theme.critical : Theme.text-secondary; stroke-width: 2px; commands: "M 0 0 L 12 12 M 12 0 L 0 12"; }
                            }
                        }
                    }

                    Rectangle {
                        height: Theme.btn-height; border-width: 1px; border-color: Theme.border; border-radius: Theme.radius/2; background: ta-add-tp.has-hover ? Theme.bg-card : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "+ Add Trusted Path"; color: ta-add-tp.has-hover ? Theme.text-main : Theme.text-muted; font-weight: 700; font-size: Theme.font-small; horizontal-alignment: center; vertical-alignment: center; }
                        ta-add-tp := TouchArea { 
                            clicked => { 
                                root.add-trusted-path();
                            } 
                        }
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // Right Column: Baton (Shell) Allowlist
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: Theme.space-lg;
                    
                    Text { text: "BATON WHITELIST (EXECUTION)"; color: Theme.text-main; font-weight: 700; font-size: Theme.font-small; }
                    Text { text: "Explicit binaries The Runner is allowed to invoke (e.g. '7z.exe', 'ffmpeg'). Shell nodes attempting unlisted binaries will abort."; color: Theme.text-muted; font-size: Theme.font-tiny+1px; wrap: word-wrap; }
                    
                    for b[idx] in root.baton-allowed: HorizontalLayout {
                        spacing: Theme.space-md;
                        InputPill { 
                            value: b; 
                            placeholder: "Program name..."; 
                            monospaced: true; 
                            horizontal-stretch: 1; 
                            committed(v) => { root.update-baton(idx, v); } 
                        }
                        ta-remove-bt := TouchArea {
                            width: Theme.btn-height; height: Theme.btn-height;
                            clicked => { root.remove-baton(idx); }
                            Rectangle {
                                border-radius: Theme.radius/2; background: ta-remove-bt.has-hover ? #ef444420 : transparent;
                                Path { width: 12px; height: 12px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; stroke: ta-remove-bt.has-hover ? Theme.critical : Theme.text-secondary; stroke-width: 2px; commands: "M 0 0 L 12 12 M 12 0 L 0 12"; }
                            }
                        }
                    }

                    Rectangle {
                        height: Theme.btn-height; border-width: 1px; border-color: Theme.border; border-radius: Theme.radius/2; background: ta-add-bt.has-hover ? Theme.bg-card : transparent;
                        animate background { duration: Theme.dur-fast; }
                        Text { text: "+ Add Allowed Binary"; color: ta-add-bt.has-hover ? Theme.text-main : Theme.text-muted; font-weight: 700; font-size: Theme.font-small; horizontal-alignment: center; vertical-alignment: center; }
                        ta-add-bt := TouchArea { clicked => { root.add-baton(); } }
                    }
                }
            }
        }
    }
}

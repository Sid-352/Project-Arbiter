//  ARBITER FORGE 

import { ScrollView, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { LogEntry, DecreeEntry, WardEntry, DecreeStep } from "models.slint";
import {
    EnvChip,
    SunIcon,
    MoonIcon,
    SidebarItem,
    InputPill,
    TextEdit,
    ActionButton,
    IconButton,
} from "widgets.slint";
import { DecreeStepItem } from "decree_step.slint";
import { ConservatoryPage } from "pages/conservatory.slint";
import { SignetPage } from "pages/signet.slint";

// ── Main Layout ───────────────────────────────────────────────────────────────


export component ArbiterForge inherits Window {
    title: "Arbiter Forge";
    icon: @image-url("../../arbiter-data/icon.ico");
    preferred-width: 1120px;
    preferred-height: 800px;
    background: Theme.bg-app;
    default-font-family: "Segoe UI Variable";
    default-font-size: 14px;

    in-out property <int> active-page: 0;
    in-out property <string> active-decree-id: "";
    in-out property <string> active-decree-label: "Untitled Decree";
    in-out property <int> active-decree-status: 0;
    in-out property <bool> context-expanded: false;
    in-out property <bool> engine-running: false;
    in-out property <string> selected-step-id: "";
    in property <[DecreeEntry]> decree-list: [];
    in property <[DecreeStep]> decree-steps: [];
    in property <[LogEntry]> telemetry-logs: [];
    in-out property <int> summons-trigger-type: 0;
    in-out property <string> summons-path: "";
    in-out property <string> summons-pattern: "";
    in-out property <bool> summons-ward-recursive: true;
    in-out property <string> summons-combo: "";
    in-out property <string> summons-process: "";
    in-out property <int> summons-ward-layer: 0;
    in-out property <bool> presence-ignore-mouse: false;
    in-out property <bool> presence-ignore-keyboard: false;
    property <bool> show-modal: false;
    property <string> modal-title: "";
    property <string> modal-message: "";
    property <int> modal-action-type: 0;
    property <string> pending-remove-decree-id: "";

    in-out property <[WardEntry]> ward-list: [];
    in-out property <[string]> trusted-paths: [];
    in-out property <[string]> baton-allowed: [];
    in-out property <bool> launch-on-startup: false;

    callback add-ward;
    callback remove-ward(string);
    callback set-ward-layer(string, int);
    callback update-ward-path(string, string);
    callback update-ward-pattern(string, string);
    callback toggle-ward-recursive(string);

    callback pick-folder() -> string;
    callback browse-monitor-path;

    callback add-trusted-path;
    callback remove-trusted-path(int);
    callback update-trusted-path(int, string);

    callback add-baton;
    callback update-baton(int, string);
    callback remove-baton(int);
    callback step-moved(string, int);

    // Explicit manual save callbacks
    callback save-wards;
    callback save-signet;

    callback save-decree;
    callback simulate-decree;
    callback new-decree;
    callback select-decree(string);
    callback append-step(int);
    callback remove-step(string);
    callback remove-decree(string);
    callback step-edited(string, string, string, string);
    callback copy-env(string);
    callback active-decree-renamed(string, string);
    callback request-close;
    public function scroll-logs-to-bottom() {
        log-scroll.viewport-y = - max(0px, log-scroll.viewport-height - log-scroll.height);
    }
    HorizontalLayout {
        Rectangle {
            width: Theme.sidebar-width;
            background: Theme.bg-sidebar;
            border-width: 1px;
            border-color: Theme.border;
            animate background { duration: Theme.dur-fast; }
            VerticalLayout {
                padding: 24px;
                spacing: 28px;

                HorizontalLayout {
                    padding-left: 4px;
                    alignment: start;
                    Text {
                        text: "ARBITER";
                        color: Theme.text-main;
                        font-size: Theme.font-large;
                        font-weight: 800;
                        letter-spacing: 1px;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    VerticalLayout {
                        padding-bottom: 4px;
                        padding-left: 4px;
                        Text {
                            text: "SYSTEM";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny + 1px;
                            font-weight: 800;
                        }
                    }

                    SidebarItem {
                        label: "Forge";
                        active: root.active-page == 0;
                        icon-commands: "M 2 6 h 10 v 4 H 2 z M 9 10 l 4 8 M 13 4 l 4 4 M 14 5 l 3 -3 2 2 -3 3";
                        clicked => {
                            root.active-page = 0;
                        }
                    }

                    SidebarItem {
                        label: "Conservatory";
                        active: root.active-page == 1;
                        icon-commands: "M 3 9 l 9 -7 l 9 7 v 11 a 2 2 0 0 1 -2 2 H 5 a 2 2 0 0 1 -2 -2 z M 9 22 V 12 h 6 v 10";
                        clicked => {
                            root.active-page = 1;
                        }
                    }

                    SidebarItem {
                        label: "Signet";
                        active: root.active-page == 2;
                        icon-commands: "M 12 2 L 3 7 v 5 c 0 5.25 3.75 10.15 9 11.25 C 17.25 22.15 21 17.25 21 12 V 7 z";
                        clicked => {
                            root.active-page = 2;
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    HorizontalLayout {
                        padding-left: 4px;
                        Text {
                            text: "DECREES";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny + 1px;
                            font-weight: 800;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => {
                                root.new-decree();
                            }
                            Rectangle {
                                border-radius: 4px;
                                background: parent.has-hover ? Theme.accent-subtle : transparent;
                                Text {
                                    text: "+";
                                    color: Theme.text-secondary;
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        clip: true;
                        VerticalLayout {
                            spacing: 2px;
                            alignment: start;
                            for item in root.decree-list: SidebarItem {
                                label: item.label;
                                active: item.id == root.active-decree-id;
                                decree-status: item.status;
                                deletable: true;
                                clicked => {
                                    root.select-decree(item.id);
                                }
                                remove => {
                                    root.modal-title = "Confirm Deletion";
                                    root.modal-message = "Delete this decree from Arbiter? This cannot be undone.";
                                    root.modal-action-type = 2;
                                    root.pending-remove-decree-id = item.id;
                                    root.show-modal = true;
                                }
                            }
                            if root.decree-list.length == 0: VerticalLayout {
                                padding: 20px;
                                Text {
                                    text: "No active decrees.";
                                    color: Theme.text-muted;
                                    font-size: Theme.font-small;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 36px;
                    border-radius: 18px;
                    background: Theme.bg-input;
                    border-width: 1px;
                    border-color: Theme.border;
                    HorizontalLayout {
                        padding: 4px;
                        spacing: 4px;
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 14px;
                            background: !Theme.is-dark ? Theme.accent : transparent;
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    alignment: center;
                                    SunIcon {
                                        icon-color: !Theme.is-dark ? #ffffff : Theme.text-muted;
                                    }
                                }
                            }

                            TouchArea {
                                clicked => {
                                    Theme.is-dark = false;
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 14px;
                            background: Theme.is-dark ? Theme.accent : transparent;
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    alignment: center;
                                    MoonIcon {
                                        icon-color: Theme.is-dark ? #ffffff : Theme.text-muted;
                                    }
                                }
                            }

                            TouchArea {
                                clicked => {
                                    Theme.is-dark = true;
                                }
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;

            Rectangle {
                height: Theme.header-height;
                background: Theme.bg-app;
                border-width: 1px;
                border-color: Theme.border;
                animate background { duration: Theme.dur-fast; }
                HorizontalLayout {
                    padding-left: 24px;
                    padding-right: 24px;
                    spacing: 20px;
                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            spacing: 12px;
                            FocusScope {
                                width: max(160px, input-label.preferred-width + 28px);
                                height: input-label.preferred-height + 10px;
                                Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    border-width: input-label.has-focus ? 1px : 0px;
                                    border-color: input-label.has-focus ? Theme.accent : transparent;
                                    border-radius: Theme.radius / 2;
                                    background: input-label.has-focus ? Theme.bg-card : transparent;
                                    animate border-color { duration: Theme.dur-fast; }
                                    animate background { duration: Theme.dur-fast; }
                                }
                                input-label := TextInput {
                                    x: 10px;
                                    y: 5px;
                                    width: parent.width - 20px;
                                    height: parent.height - 10px;
                                    text <=> root.active-decree-label;
                                    color: Theme.text-main;
                                    font-size: Theme.font-large + 2px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    single-line: true;
                                    edited => {
                                        root.active-decree-renamed(root.active-decree-id, self.text);
                                    }
                                    accepted => {
                                        root.active-decree-renamed(root.active-decree-id, self.text);
                                    }
                                }

                                focus-lost(reason) => {
                                    root.active-decree-renamed(root.active-decree-id, input-label.text);
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    VerticalLayout {
                        alignment: center;
                        ActionButton {
                            label: "SIMULATE DECREE";
                            width: 160px;
                            clicked => {
                                root.simulate-decree();
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        ActionButton {
                            label: "COMMIT TO ENGINE";
                            primary: true;
                            width: 160px;
                            clicked => {
                                root.modal-title = "Confirm Deployment";
                                root.modal-message = "Submit this decree to the Arbiter core? This will update active triggers.";
                                root.modal-action-type = 1;
                                root.show-modal = true;
                            }
                        }
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                clip: true;
                background: Theme.bg-app;
                animate background { duration: Theme.dur-slow; }

                // ── Empty State: no decree selected
                if root.active-page == 0 && root.active-decree-id == "": VerticalLayout {
                    alignment: center;
                    spacing: Theme.space-lg;
                    VerticalLayout {
                        alignment: center;
                        spacing: Theme.space-md;
                        HorizontalLayout {
                            alignment: center;
                            Path {
                                width: 48px;
                                height: 48px;
                                viewbox-width: 24;
                                viewbox-height: 24;
                                stroke: Theme.border;
                                stroke-width: 1.5px;
                                fill: transparent;
                                commands: "M 14 2 H 6 a 2 2 0 0 0 -2 2 v 16 a 2 2 0 0 0 2 2 h 12 a 2 2 0 0 0 2 -2 V 8 z M 14 2 v 6 h 6 M 12 18 v -6 M 9 15 h 6";
                            }
                        }

                        Text {
                            text: "No Decree Selected";
                            color: Theme.text-secondary;
                            font-size: Theme.font-large;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Select an existing decree from the sidebar,\nor create a new one with the + button.";
                            color: Theme.text-muted;
                            font-size: Theme.font-norm;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                // ── Editor: decree is active
                if root.active-page == 0 && root.active-decree-id != "": ScrollView {
                    // Background deselect — clicking anywhere outside a step clears selection
                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.selected-step-id = "";
                        }
                    }
                    VerticalLayout {
                        padding: 40px;
                        spacing: 40px;
                        alignment: start;

                        VerticalLayout {
                            spacing: 16px;
                            Text {
                                text: "Trigger";
                                color: Theme.text-secondary;
                                font-size: Theme.font-small;
                                font-weight: 600;
                            }

                            Rectangle {
                                background: Theme.bg-card;
                                border-radius: Theme.radius;
                                border-width: 1px;
                                border-color: Theme.border;
                                VerticalLayout {
                                    padding: 20px;
                                    spacing: 20px;

                                    Rectangle {
                                        height: 34px;
                                        background: Theme.bg-input;
                                        border-radius: 6px;
                                        HorizontalLayout {
                                            padding: 2px;
                                            for t[i] in ["FILE SYSTEM", "HOTKEY", "PROCESS"]: Rectangle {
                                                horizontal-stretch: 1;
                                                border-radius: 4px;
                                                background: root.summons-trigger-type == i ? Theme.bg-card : transparent;
                                                border-width: 1.5px;
                                                border-color: root.summons-trigger-type == i ? Theme.accent : transparent;
                                                animate border-color { duration: Theme.dur-fast; }
                                                Text {
                                                    text: t;
                                                    color: root.summons-trigger-type == i ? Theme.text-main : Theme.text-muted;
                                                    font-size: Theme.font-tiny + 1px;
                                                    font-weight: 800;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }

                                                TouchArea {
                                                    clicked => {
                                                        root.summons-trigger-type = i;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    if root.summons-trigger-type == 0: HorizontalLayout {
                                        spacing: Theme.space-md;
                                        VerticalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 2;
                                            Text {
                                                text: "Monitor Path";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            InputPill {
                                                value <=> root.summons-path;
                                                placeholder: "C:\\Inbound\\";
                                                monospaced: true;
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;
                                            width: Theme.btn-height;
                                            Text {
                                                text: "";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            IconButton {
                                                icon-commands: "M 11 19 A 8 8 0 1 1 19 11 M 22 22 L 17 17";
                                                clicked => {
                                                    root.browse-monitor-path();
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 1;
                                            min-width: 140px;
                                            Text {
                                                text: "File Pattern";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            InputPill {
                                                value <=> root.summons-pattern;
                                                placeholder: "e.g. *.pdf";
                                                monospaced: true;
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;
                                            width: 100px;
                                            Text {
                                                text: "Recursion";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            Rectangle {
                                                height: Theme.input-height;
                                                background: Theme.bg-input;
                                                border-radius: 6px;
                                                ta-rec := TouchArea {
                                                    clicked => {
                                                        root.summons-ward-recursive = !root.summons-ward-recursive;
                                                    }
                                                }

                                                Text {
                                                    text: root.summons-ward-recursive ? "Recursive" : "Shallow";
                                                    color: root.summons-ward-recursive ? Theme.accent : Theme.text-muted;
                                                    font-size: Theme.font-tiny + 1px;
                                                    font-weight: 600;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                    if root.summons-trigger-type == 1: HorizontalLayout {
                                        spacing: 12px;
                                        VerticalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Key Combination";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            InputPill {
                                                value <=> root.summons-combo;
                                                placeholder: "Ctrl+Alt+S";
                                                monospaced: true;
                                            }
                                        }
                                    }
                                    if root.summons-trigger-type == 2: HorizontalLayout {
                                        spacing: 12px;
                                        VerticalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: "Process Name";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }

                                            InputPill {
                                                value <=> root.summons-process;
                                                placeholder: "notepad.exe";
                                                monospaced: true;
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 20px;
                                        VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: "Yield on mouse";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }
                                        }

                                        Rectangle {
                                            width: 56px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: root.presence-ignore-mouse ? Theme.accent : Theme.bg-input;
                                            animate background { duration: Theme.dur-fast; }
                                            TouchArea {
                                                clicked => {
                                                    root.presence-ignore-mouse = !root.presence-ignore-mouse;
                                                }
                                            }

                                            Rectangle {
                                                x: root.presence-ignore-mouse ? parent.width - self.width - 3px : 3px;
                                                y: 3px;
                                                width: 18px;
                                                height: 18px;
                                                border-radius: 9px;
                                                background: Theme.text-main;
                                                animate x {
                                                    duration: Theme.dur-fast;
                                                    easing: ease-in-out;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            width: 20px;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: "Yield on key";
                                                color: Theme.text-muted;
                                                font-size: Theme.font-tiny + 1px;
                                            }
                                        }

                                        Rectangle {
                                            width: 56px;
                                            height: 24px;
                                            border-radius: 12px;
                                            background: root.presence-ignore-keyboard ? Theme.accent : Theme.bg-input;
                                            animate background { duration: Theme.dur-fast; }
                                            TouchArea {
                                                clicked => {
                                                    root.presence-ignore-keyboard = !root.presence-ignore-keyboard;
                                                }
                                            }

                                            Rectangle {
                                                x: root.presence-ignore-keyboard ? parent.width - self.width - 3px : 3px;
                                                y: 3px;
                                                width: 18px;
                                                height: 18px;
                                                border-radius: 9px;
                                                background: Theme.text-main;
                                                animate x {
                                                    duration: Theme.dur-fast;
                                                    easing: ease-in-out;
                                                }
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 16px;
                            HorizontalLayout {
                                Text {
                                    text: "Sequence";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-small;
                                    font-weight: 600;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }
                            }

                            VerticalLayout {
                                spacing: 12px;
                                for step[idx] in root.decree-steps: DecreeStepItem {
                                    step-id: step.id;
                                    title: step.title;
                                    subtext: step.subtext;
                                    step-type: step.step-type;
                                    trigger-type: root.summons-trigger-type;
                                    baton-required: step.baton-required;
                                    is-active: step.is-active;
                                    is-running: root.engine-running && step.is-active;
                                    is-editing: step.id == root.selected-step-id;
                                    is-last: idx == root.decree-steps.length - 1;
                                    arg-a: step.arg-a;
                                    arg-b: step.arg-b;
                                    edited(id, t, a, b) => {
                                        root.step-edited(id, t, a, b);
                                    }
                                    remove => {
                                        root.remove-step(step.id);
                                    }
                                    selected => {
                                        root.selected-step-id = step.id;
                                    }
                                }
                                if root.decree-steps.length == 0: Rectangle {
                                    height: 100px;
                                    border-radius: Theme.radius;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    Text {
                                        text: "Sequence is empty. Append an action below.";
                                        color: Theme.text-muted;
                                        font-size: Theme.font-norm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                padding-top: 12px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    height: Theme.input-height;
                                    ActionButton {
                                        horizontal-stretch: 1;
                                        label: "Move / Copy";
                                        clicked => {
                                            root.append-step(0);
                                        }
                                    }

                                    ActionButton {
                                        horizontal-stretch: 1;
                                        label: "Script";
                                        clicked => {
                                            root.append-step(1);
                                        }
                                    }

                                    ActionButton {
                                        horizontal-stretch: 1;
                                        label: "Type text";
                                        clicked => {
                                            root.append-step(2);
                                        }
                                    }

                                    ActionButton {
                                        horizontal-stretch: 1;
                                        label: "Wait";
                                        clicked => {
                                            root.append-step(3);
                                        }
                                    }

                                    ActionButton {
                                        horizontal-stretch: 1;
                                        label: "Keypress";
                                        clicked => {
                                            root.append-step(4);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.active-page == 1: ConservatoryPage {
                    wards <=> root.ward-list;
                    add-ward => {
                        root.add-ward()
                    }
                    remove-ward(id) => {
                        root.remove-ward(id)
                    }
                    set-layer(id, l) => {
                        root.set-ward-layer(id, l)
                    }
                    update-path(id, p) => {
                        root.update-ward-path(id, p)
                    }
                    update-pattern(id, p) => {
                        root.update-ward-pattern(id, p)
                    }
                    toggle-recursive(id) => {
                        root.toggle-ward-recursive(id)
                    }
                    pick-folder => {
                        root.pick-folder()
                    }
                    save => {
                        root.save-wards()
                    }
                }

                if root.active-page == 2: SignetPage {
                    trusted-paths <=> root.trusted-paths;
                    baton-allowed <=> root.baton-allowed;
                    launch-on-startup <=> root.launch-on-startup;
                    add-trusted-path => {
                        root.add-trusted-path()
                    }
                    remove-trusted-path(idx) => {
                        root.remove-trusted-path(idx)
                    }
                    update-trusted-path(idx, p) => {
                        root.update-trusted-path(idx, p)
                    }
                    add-baton => {
                        root.add-baton()
                    }
                    update-baton(idx, b) => {
                        root.update-baton(idx, b)
                    }
                    remove-baton(idx) => {
                        root.remove-baton(idx)
                    }
                    pick-folder => {
                        root.pick-folder()
                    }
                    save => {
                        root.save-signet()
                    }
                }
            }

            // ── Context Ribbon Header (Toggle) ────────────────────────────────
            if root.active-page == 0: Rectangle {
                height: Theme.input-height;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border;
                z: 1000;

                TouchArea {
                    clicked => {
                        root.context-expanded = !root.context-expanded;
                    }
                }

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 12px;
                    alignment: start;
                    vertical-stretch: 1;

                    VerticalLayout {
                        alignment: center;
                        height: Theme.input-height;
                        Path {
                            width: 12px;
                            height: 12px;
                            viewbox-width: 24;
                            viewbox-height: 24;
                            stroke: Theme.accent;
                            stroke-width: 2.5px;
                            commands: root.context-expanded ? "M 4 15 L 12 7 L 20 15" : "M 4 9 L 12 17 L 20 9";
                        }
                    }

                    Text {
                        text: "Context variables [Click to copy]";
                        color: Theme.text-secondary;
                        font-size: Theme.font-tiny + 1px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }

            // ── Expandable Tray (Reference Library Grid) ──────────────────────
            if root.active-page == 0: Rectangle {
                height: root.context-expanded ? 200px : 0px;
                background: Theme.bg-sidebar;
                opacity: 0.95;
                drop-shadow-blur: root.context-expanded ? 24px : 0px;
                drop-shadow-offset-y: 12px;
                drop-shadow-color: Theme.is-dark ? #00000080 : #00000020;
                border-width: root.context-expanded ? 1px : 0px;
                border-color: Theme.border;
                clip: true;
                z: 900;
                animate height {
                    duration: 100ms;
                    easing: ease-out;
                }

                HorizontalLayout {
                    padding: 16px;
                    padding-left: 24px;
                    padding-right: 24px;
                    spacing: 32px;
                    alignment: start;

                    // Col 1: OS PHYSICAL
                    VerticalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "Artifact";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny;
                            font-weight: 700;
                        }

                        for t in [
                            "${env.file_name}",
                            "${env.file_ext}",
                            "${env.file_dir}",
                            "${env.file_path}",
                            "${env.file_size_human}",
                            "${env.file_owner}"
                        ]: EnvChip {
                            token: t;
                            clicked(v) => {
                                root.copy-env(v);
                            }
                        }
                    }

                    Rectangle {
                        width: 1px;
                        background: Theme.border;
                    }

                    // Col 2: TEMPORAL
                    VerticalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "Temporal";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny;
                            font-weight: 700;
                        }

                        for t in [
                            "${env.timestamp}",
                            "${env.timestamp_local}",
                            "${env.file_created_local}",
                            "${env.file_modified_local}",
                            "${env.file_created_iso}",
                            "${env.file_created_unix}"
                        ]: EnvChip {
                            token: t;
                            clicked(v) => {
                                root.copy-env(v);
                            }
                        }
                    }

                    Rectangle {
                        width: 1px;
                        background: Theme.border;
                    }

                    // Col 3: CONTENT
                    VerticalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "Content";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny;
                            font-weight: 700;
                        }

                        for t in [
                            "${env.content_sha256}",
                            "${env.content_mime}",
                            "${env.content_md5}",
                            "${env.content_entropy}",
                            "${env.text_lines}"
                        ]: EnvChip {
                            token: t;
                            clicked(v) => {
                                root.copy-env(v);
                            }
                        }
                    }

                    Rectangle {
                        width: 1px;
                        background: Theme.border;
                    }

                    // Col 4: SIGNALS
                    VerticalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "Signals";
                            color: Theme.text-muted;
                            font-size: Theme.font-tiny;
                            font-weight: 700;
                        }

                        for t in ["${env.process_name}", "${env.process_pid}", "${env.hotkey_combo}"]: EnvChip {
                            token: t;
                            clicked(v) => {
                                root.copy-env(v);
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: Theme.log-height;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border;
                VerticalLayout {
                    padding: 12px;
                    padding-left: 20px;
                    padding-right: 20px;
                    HorizontalLayout {
                        spacing: 8px;
                        height: 14px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: Theme.success;
                                vertical-stretch: 0;
                            }
                        }

                        Text {
                            text: "Live telemetry";
                            color: Theme.text-secondary;
                            font-size: Theme.font-tiny + 1px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle {
                        height: 6px;
                    }

                    log-scroll := ScrollView {
                        VerticalLayout {
                            alignment: start;
                            for entry in root.telemetry-logs: HorizontalLayout {
                                spacing: 12px;
                                height: 18px;
                                Text {
                                    text: entry.time;
                                    color: Theme.text-muted;
                                    font-size: Theme.font-tiny;
                                    font-family: "Consolas";
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: entry.tag;
                                    color: entry.tag-color;
                                    font-size: Theme.font-tiny;
                                    font-weight: 700;
                                    font-family: "Consolas";
                                    vertical-alignment: center;
                                    width: 60px;
                                }

                                Text {
                                    text: entry.msg;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-tiny;
                                    vertical-alignment: center;
                                    height: 16px;
                                    horizontal-stretch: 1;
                                    font-family: "Consolas";
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.show-modal: Rectangle {
        background: #00000080;
        TouchArea { }

        Rectangle {
            width: Theme.modal-width;
            height: 220px;
            background: Theme.bg-card;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000040;
            VerticalLayout {
                padding: 32px;
                spacing: 20px;
                Text {
                    text: root.modal-title;
                    color: Theme.text-main;
                    font-size: Theme.font-title;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: root.modal-message;
                    color: Theme.text-secondary;
                    font-size: Theme.font-norm + 1px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 12px;
                    ActionButton {
                        horizontal-stretch: 1;
                        label: "CANCEL";
                        clicked => {
                            root.show-modal = false;
                            root.pending-remove-decree-id = "";
                        }
                    }

                    ActionButton {
                        horizontal-stretch: 1;
                        label: "CONFIRM";
                        primary: true;
                        clicked => {
                            root.show-modal = false;
                            if (root.modal-action-type == 1) {
                                root.save-decree();
                            } else if (root.modal-action-type == 2) {
                                root.remove-decree(root.pending-remove-decree-id);
                                root.pending-remove-decree-id = "";
                            }
                        }
                    }
                }
            }
        }
    }
}
